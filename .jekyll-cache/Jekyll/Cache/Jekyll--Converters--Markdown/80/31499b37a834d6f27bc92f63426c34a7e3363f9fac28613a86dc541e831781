        <span class="nt">&lt;nav&gt;</span>
            <span class="nt">&lt;a</span> <span class="na">href=</span><span class="s">"#privacy"</span><span class="nt">&gt;</span>Privacy<span class="nt">&lt;/a&gt;</span> |
